<% status = expense.payment_status %>
<% return unless status.present? %>

<%
  style = case status
  when "pending"   then "background-color: rgba(255,107,107,0.15); color: #FF6B6B;"
  when "scheduled" then "background-color: rgba(99,102,241,0.15); color: #818CF8;"
  when "paid"      then "background-color: rgba(34,197,94,0.15); color: #22C55E;"
  else ""
  end
  label = t("expenses.payment_statuses.#{status}", default: status.humanize)
%>

<%= button_to update_status_expense_path(expense),
    method: :patch,
    title: t("expenses.payment_statuses.click_to_advance"),
    form: { style: "display: inline;", data: { turbo_stream: true } },
    class: "text-xs font-medium rounded cursor-pointer transition-opacity hover:opacity-70",
    style: "#{style} border: none; padding: 2px 6px; line-height: 1.25rem;" do %>
  <%= label %>
<% end %>
