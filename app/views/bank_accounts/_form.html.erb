<%= form_with model: bank_account, data: { controller: "bank-account-rate" }, class: "space-y-4" do |f| %>
  <% if bank_account.errors.any? %>
    <div class="px-4 py-3 rounded-lg border text-sm" style="background-color: rgba(255,107,107,0.1); border-color: #FF6B6B; color: #FF6B6B;">
      <% bank_account.errors.full_messages.each do |msg| %><p><%= msg %></p><% end %>
    </div>
  <% end %>

  <div class="grid grid-cols-2 gap-3">
    <div>
      <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;"><%= t("bank_accounts.form.name") %></label>
      <%= f.text_field :name, class: "w-full px-3 py-2.5 rounded-lg border text-sm outline-none transition-all", style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;", placeholder: t("bank_accounts.form.name_placeholder"), autofocus: true %>
    </div>
    <div>
      <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;"><%= t("bank_accounts.form.bank_name") %></label>
      <%= f.text_field :bank_name, class: "w-full px-3 py-2.5 rounded-lg border text-sm outline-none transition-all", style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;", placeholder: t("bank_accounts.form.bank_name_placeholder") %>
    </div>
  </div>

  <div>
    <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;"><%= t("bank_accounts.form.account_type") %></label>
    <%= f.select :account_type,
        [[t("bank_accounts.form.checking"), "checking"], [t("bank_accounts.form.savings"), "savings"], [t("bank_accounts.form.other"), "other"]],
        {},
        class: "w-full px-3 py-2.5 rounded-lg border text-sm outline-none transition-all",
        style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;" %>
  </div>

  <div>
    <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;"><%= t("bank_accounts.form.balance") %></label>
    <div data-controller="currency-input">
      <%= f.hidden_field :balance, data: { currency_input_target: "hidden" } %>
      <input type="text"
             inputmode="numeric"
             autocomplete="off"
             data-currency-input-target="display"
             data-action="input->currency-input#input"
             class="w-full px-3 py-2.5 rounded-lg border text-sm outline-none transition-all"
             style="background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;"
             placeholder="0,00">
    </div>
  </div>

  <div>
    <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;"><%= t("bank_accounts.form.rate_type") %></label>
    <%= f.select :rate_type,
        [[t("bank_accounts.form.fixed_rate"), "fixed"], [t("bank_accounts.form.cdi_percent"), "cdi_percentage"]],
        {},
        class: "w-full px-3 py-2.5 rounded-lg border text-sm outline-none transition-all",
        style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;",
        data: { "bank-account-rate-target": "rateTypeSelect", action: "change->bank-account-rate#toggle" } %>
  </div>

  <div data-bank-account-rate-target="fixedFields">
    <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;"><%= t("bank_accounts.form.interest_rate") %></label>
    <%= f.number_field :interest_rate, step: "0.0001", min: "0", class: "w-full px-3 py-2.5 rounded-lg border text-sm outline-none transition-all", style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;", placeholder: "0.00" %>
  </div>

  <div data-bank-account-rate-target="cdiFields" class="hidden">
    <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;"><%= t("bank_accounts.form.cdi_multiplier") %></label>
    <%= f.number_field :cdi_multiplier, step: "0.01", min: "0.01", class: "w-full px-3 py-2.5 rounded-lg border text-sm outline-none transition-all", style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;", placeholder: "100.00" %>
    <% if @cdi_info %>
      <p class="mt-1.5 text-xs" style="color: #00D4AA;">
        <%= t("bank_accounts.form.current_cdi") %> <%= number_with_precision(@cdi_info[:rate], precision: 2) %><%= t("bank_accounts.form.pa") %>
        (<%= t("bank_accounts.form.as_of") %> <%= @cdi_info[:date] %>, <%= t("bank_accounts.form.updated") %> <%= time_ago_in_words(@cdi_info[:updated_at]) %> <%= t("bank_accounts.form.ago") %>)
      </p>
    <% else %>
      <p class="mt-1.5 text-xs" style="color: #F7B731;"><%= t("bank_accounts.form.cdi_not_available") %></p>
    <% end %>
  </div>

  <div>
    <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;"><%= t("bank_accounts.form.color") %></label>
    <div class="flex flex-wrap gap-2">
      <% ColorPalette::COLORS.each do |color| %>
        <label class="cursor-pointer">
          <%= f.radio_button :color, color, class: "sr-only peer" %>
          <span class="block w-8 h-8 rounded-lg peer-checked:ring-2 peer-checked:ring-offset-2 peer-checked:ring-offset-[#1E2130] peer-checked:ring-white transition-all"
                style="background-color: <%= color %>;"></span>
        </label>
      <% end %>
    </div>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit bank_account.new_record? ? t("bank_accounts.form.add") : t("bank_accounts.form.update"), class: "flex-1 py-2.5 rounded-lg text-sm font-semibold cursor-pointer transition-colors hover:opacity-90", style: "background-color: #6C63FF; color: white;" %>
    <%= link_to t("bank_accounts.form.cancel"), bank_accounts_path, class: "px-4 py-2.5 rounded-lg text-sm font-medium transition-colors hover:bg-white/5", style: "color: #8892A4;" %>
  </div>
<% end %>
