<%= form_with model: payee, class: "space-y-4" do |f| %>
  <% if payee.errors.any? %>
    <div class="px-4 py-3 rounded-lg border text-sm" style="background-color: rgba(255,107,107,0.1); border-color: #FF6B6B; color: #FF6B6B;">
      <ul class="space-y-1">
        <% payee.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;"><%= t("payees.form.name") %></label>
    <%= f.text_field :name,
        class: "w-full px-3 py-2.5 rounded-lg border text-sm outline-none focus:ring-2 transition-all",
        style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;",
        placeholder: t("payees.form.name_placeholder"),
        autofocus: true %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit payee.new_record? ? t("payees.form.add") : t("payees.form.update"),
        class: "flex-1 py-2.5 rounded-lg text-sm font-semibold cursor-pointer transition-colors hover:opacity-90",
        style: "background-color: #6C63FF; color: white;" %>
    <%= link_to t("payees.form.cancel"), payees_path,
        class: "px-4 py-2.5 rounded-lg text-sm font-medium transition-colors hover:bg-white/5",
        style: "color: #8892A4;" %>
  </div>
<% end %>
